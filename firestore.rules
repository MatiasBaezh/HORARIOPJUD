rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'matiasbaezh@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    function isValidAttendanceRecord(data) {
      return data.employeeName is string && data.employeeName.size() <= 200 &&
             data.date is string;
    }

    match /records/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin() && isValidAttendanceRecord(request.resource.data);
    }

    match /exceptions/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /hybrid_schedules/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /general_exceptions/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /particular_incidents/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /upload_history/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /settings/config {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false; // Only manageable via console
    }
  }
}
