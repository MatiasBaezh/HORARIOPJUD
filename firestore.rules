rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    function isValidAttendanceRecord(data) {
      return data.employeeName is string && data.employeeName.size() <= 200 &&
             data.date is string;
    }

    match /records/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidAttendanceRecord(request.resource.data);
    }

    match /exceptions/{id} {
      allow read, write: if request.auth != null;
    }

    match /hybrid_schedules/{id} {
      allow read, write: if request.auth != null;
    }

    match /general_exceptions/{id} {
      allow read, write: if request.auth != null;
    }

    match /particular_incidents/{id} {
      allow read, write: if request.auth != null;
    }

    match /upload_history/{id} {
      allow read, write: if request.auth != null;
    }

    match /settings/config {
      allow read, write: if request.auth != null;
    }
  }
}
